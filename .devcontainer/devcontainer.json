// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
  "name": "Python 3 + Go",
  // Build from Dockerfile so we can remove the broken Yarn apt source before installing Go
  "build": { "dockerfile": "Dockerfile" },

  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": "pip3 install --user -r requirements.txt 2>/dev/null || true",

  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ]
    }
  }

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [],

  // Uncomment to connect as root instead. More info: https://containers.dev/dev-containers-non-root.
  // "remoteUser": "root"
}
